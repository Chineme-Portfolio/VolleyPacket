# ── Auth (REQUIRED) ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Google OAuth (optional, leave blank to disable) ──────────────────
GOOGLE_CLIENT_ID=

# ── AI Features ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Stripe Billing (optional for dev) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CLASSIC=
STRIPE_PRICE_PRO=

# ── Frontend URL (for Stripe redirects) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS (comma-separated origins, required in production) ───────────
CORS_ORIGINS=http://localhost:3000

# ── Storage (auto-detected on Railway) ───────────────────────────────
# Railway auto-injects BUCKET, ACCESS_KEY_ID, etc. when you link a bucket.
# For local dev, leave unset — defaults to filesystem.
# To force local even when S3 vars exist: STORAGE_BACKEND=local
# STORAGE_BACKEND=

# ── Paystack Billing (for Nigerian users, optional for dev) ──────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_PLAN_CLASSIC=
PAYSTACK_PLAN_PRO=

# ── Legacy (only needed on 'local' branch) ───────────────────────────
# SMTP_LOGIN=
# SMTP_PASSWORD=
# SENDER_EMAIL=
# BREVO_API_KEY=
# BULKSMS_API_TOKEN=
# RESEND_API_KEY=
