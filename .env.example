# ── Auth (REQUIRED) ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Google OAuth (optional, leave blank to disable) ──────────────────
GOOGLE_CLIENT_ID=

# ── AI Features ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Stripe Billing (optional for dev) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CLASSIC=
STRIPE_PRICE_PRO=

# ── Frontend URL (for Stripe redirects) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS (comma-separated origins, required in production) ───────────
CORS_ORIGINS=http://localhost:3000

# ── Storage (default: local filesystem) ──────────────────────────────
# Set to "s3" in production for persistent file storage
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# ── Paystack Billing (for Nigerian users, optional for dev) ──────────
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_PLAN_CLASSIC=
PAYSTACK_PLAN_PRO=

# ── Legacy (only needed on 'local' branch) ───────────────────────────
# SMTP_LOGIN=
# SMTP_PASSWORD=
# SENDER_EMAIL=
# BREVO_API_KEY=
# BULKSMS_API_TOKEN=
# RESEND_API_KEY=
